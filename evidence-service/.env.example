# This file provides an example environment variable configuration for the application.

# Database configuration
DATABASE_URL=sqlite:///evidence.db

# Encryption key for file encryption
FERNET_KEY=

# Redis configuration for task queue (if applicable)
REDIS_URL=redis://localhost:6379/0

# Other environment-specific settings
DEBUG=True
SECRET_KEY=your_secret_key_here
AUDIT_LOGGING_ENABLED=True